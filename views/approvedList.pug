extends layout
block content
    header.card-header
        h4.card-title List of Products 
    br
    nav
    #nav-tab.nav.nav-tabs(role='tablist')
        a#nav-profile-tab.nav-item.nav-link(href='/producelist') A
    #nav-tabContent.tab-content
    br
    table.table.table-bordered 
        thead
            tr
                th Produce Name
                th Quantity
                th Unit Price
                th Total Amount
                th Product Type
                th Mode of Payment
                th Mode of Delivery
                th Image 
                th Update
                th Availability 
                th Delete
        tbody
            if farmproducts.length
                each item in farmproducts
                    if item.status=='Approved'
                        tr
                            td #{item.productname}
                            td #{item.quantity}
                            td #{item.unitprice}
                            td #{item.totalamount}
                            td #{item.producttype}
                            td #{item.modeofpayment}
                            td #{item.modeofdelivery}
                            td 
                                img(src="/"+product.uploadimage, alt="Image" width='150px' height="150px")
                            td
                                a.btn.btn-secondary.btn-block(href='/produce/update/'+item._id) Availability
                            td
                                form(method="post" action='/farmerOne/delete')
                                    input(type="hidden" placeholder="" name="id", value=product._id)
    div.form-row
        div.col.form-group
            a(class='button' href='/agricOfficerDash') Back

block footer
    div.col-md-12 

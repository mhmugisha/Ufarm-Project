doctype html
head
  meta(charset='UTF-8')
  meta(http-equiv='X-UA-Compatible' content='IE=edge')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  link(rel='stylesheet' href='https://unicons.iconscout.com/release/v4.0.0/css/line.css')
  link(rel='stylesheet' href='../css/foregistration.css')
  title Farmer One Regisration
.container
  header.heading Farmer One Registration
  hr
  form(action='/foregister' method='post' onsubmit="return formValidatefo(event);")
    .form.first
      .details.personal
        .fields
          .input-field
            label Unique ID
            input#uniqueid(type='text' name='uniqueid' placeholder='Unique ID')
            small#uniqueidError
          .input-field
            label Role
            select#role(type='text' name='role')
              option(value='') Select role
              option(value='farmerone') Farmer One
            small#roleError
          .input-field
            label First and Last Name
            input#fullname(type='text' name='fullname' placeholder='Enter full name')
            small#fullNameError
          .input-field
            label NIN
            input#nin(type='text' name='nin' placeholder='Enter NIN')
            small#ninError  
          .input-field
            label Date of Birth
            input#dob(type='date' name='dob' placeholder='Date of birth')
            small#dobError
          .input-field
            label Date of Registration
            input#doreg(type='date' name='doreg' placeholder='Date of registration')
            small#doregError
          .input-field
            label Phone Number
            input#phone(type='text' name='phone' placeholder='Phone number')
            small#phoneNumberError
          .input-field
            label.details Password
            input#password(type='password' name='password' placeholder='Password')
            small#passwordError
          .input-field
            label Gender
            select#gender(type='text' name='gender')
              option(value='') Select gender
              option(value="Male") Male
              option(value="Female") Female
            small#genderError         
      .details.ID
        .fields
          .input-field
            label Activity
            select#activity(type='text' name='activity')
              option(value='') Farming activity
              option(value="Horticulture") Horticulture
              option(value="Poultry") Poultry
              option(value="Dairy") Dairy
            small#activityError
          .input-field
            label Ward
            select#ward(type='text' name='ward')
              option(value='') Select ward
              option(value="Masajja A") Masajja A
              option(value="Masajja B") Masajja B
              option(value="Masajja C") Masajja C
              option(value="Masajja D") Masajja D
            small#wardError  
          .input-field
            label Residence Type
            select#residencetype(type='text' name='residencetype')
              option(value='') Residence type
              option(value="Permanent") Permanent
              option(value="Temporary") Temporary
            small#residencetypeError
          .input-field
            label Years at Residence
            select#duration(type='number' name='duration' min='10')
              option(value='') Years at residence
              //- option 10
              //- option 11
              //- option 12
              //- option 13
              //- option 14
              //- option 15
              //- option 16
              //- option 17
              //- option 18
              //- option 19
            small#durationError
          .input-field
            label Home Address
            input#address(type='text' name='address' placeholder='Home directions')
            small#addressError   
        .button
            input#btnSubmit(type='submit' value='Register')
  script(src="/JS/form_validationfo.js") 

  

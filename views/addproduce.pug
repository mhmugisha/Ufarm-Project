doctype html
head
  meta(charset='UTF-8')
  meta(http-equiv='X-UA-Compatible' content='IE=edge')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  link(rel='stylesheet' href='https://unicons.iconscout.com/release/v4.0.0/css/line.css')
  link(rel='stylesheet' href='css/pdtupdate.css')
  title UFarm Product Add
.container
  header.heading Product Update
  hr
  form(action='/addproduce' method='post' enctype='multipart/form-data')
    .form.first
      .details.personal
        .fields
          .input-field
            label Unique ID
            select(type='text' name='uniqueid')
              if currentUser
                option(value=currentUser._id) #{currentUser.uniqueid}
          .input-field
            label Supplier Name
            select(type='text' name='suppliername' required='')
              if currentUser
                option(value=currentUser._id) #{currentUser.fullname}
          .input-field
            label Date of Registration
            input(type='date' name='doreg' placeholder='Date of registraion' required='')
          .input-field
            label Home Address
            input(type='text' name='address' placeholder='Home directions' required='')
          .input-field
            label Product
            input(type='text' name='product' placeholder='Product' required='')
      .details.ID
        .fields
          .input-field
            label Quantity
            input(type='number' name='quantity' placeholder='Quantity' required='')
          .input-field
            label Unit Price
            input(type='number' name='unitprice' placeholder='Unit price' required='')
          .input-field
            label Total Amount
            input(type='number' name='totalamount' placeholder='Total amount' required='')
          .input-field
            label Product Type
            select(type='text' name='producttype' required='')
              option(value='') Product type
              option(value='organic') Organic
              option(value='nonorganic') Non Organic
          .input-field
            label Mode of Payment
            select(type='text' name='modeofpay' required='')
              option(value='') Mode of payment
              option(value='cash') Cash
              option(value='mobilemoney') Mobile Money
          .input-field
            label Mode of Delivery
            select(type='text' name='deliverymode')
              option(value='') Mode of delivery
              option(value='pickup') Pickup
              option(value='delivery') Home Delivery
          .input-field
            label Ward 
            select(type='text' name='ward')
              if currentUser
                option(value=currentUser._id) #{currentUser.ward}  
          .input-field 
            label Produce Image:
            input#image(type='file' name='uploadimage' autocomplete='off')        
        .button
          input#btnSubmit(type='submit' value='Add Produce')


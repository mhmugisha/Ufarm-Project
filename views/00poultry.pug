doctype html
head
  title UFarm
  // Required meta tags
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  // Bootstrap CSS v5.2.0-beta1
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css' integrity='sha384-gH2yIJqKdNHPEq0n4Mqa/HGKIhSkIHeL5AyhkYV8i59U5AR6csBvApHHNl/vI1Bx' crossorigin='anonymous')
  link(rel="stylesheet", href="css/orders.css")
header
    .container.my-5
        .row.justify-content-center.align-items-center.g-2.my-5
            .col.my-5
                .row
                    if poultryProduces.length
                        each poultryproduce in poultryProduces
                            if poultryproduce.availability == 'available' && poultryproduce.status == 'Approved' && poultryproduce.productcategory == "Poultry"
                                .col-3
                                        img(src="/"+poultryproduce.uploadimage, alt="uploadimage")
                                        .card-body
                                            h5.card-title Product: #{poultryproduce.productname}
                                            h5.card-title Price: #{new Intl.NumberFormat().format(poultryproduce.unitprice)} UGX  
                                            a.btn(href='/produce/order/'+poultryproduce._id) Order
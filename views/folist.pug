extends layout
block content
    header.card-header
        h4.card-title List of Farmer ones
    br
    table.table.table-bordered 
        thead
            tr
                th Unique ID  
                th Full Name 
                th NIN
                th Phone number
                th Ward
                th Update
        tbody
            if farmerones.length
                each farmerone in farmerones
                    if farmerone.uniqueid == currentUser.uniqueid
                    tr
                        td #{farmerone.uniqueid}
                        td #{farmerone.fullname}
                        td #{farmerone.nin}
                        td #{farmerone.phone}
                        td #{farmerone.ward}
                        td
                            a.button.btn.btn-success.btn-block(href='/farmerone/update/'+farmerone._id) Update
                            //- div.form-row
        div.col.form-group
            a.btn.btn-success.text-white(class='button' href='/aodashboardroute') Back
    
block footer
    div.col-md-12 
doctype html
head
    meta(charset='UTF-8')
    meta(http-equiv='X-UA-Compatible' content='IE=edge')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    link(rel='stylesheet' href='bootstrap-css/css/bootstrap.css')
    link(rel='stylesheet' href='css/style.css')
    title Produce Update
.container-fluid.form-style
    form#signup.form(action='/produce/approve/?id='+product._id name='productupdate' method='POST')
        h3 Update Produce 
        hr
        .row
            .col
                .form-field
                    label(for='status') Status:
                    select(name='status')
                        //- option(value="Pending" selected = product.status === 'Pending') Pending
                        //- option(value="Approved" selected = product.status === 'Approved') Approved 
                        option(value="Pending" ) Pending
                        option(value="Approved") Approved 
                .form-field
                    input.btn.register-btn(type='submit' value='Update')
script(src='bootstrap-js/js/bootstrap.bundle.js')

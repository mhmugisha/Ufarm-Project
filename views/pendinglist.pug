extends layoutlists 
block content
    header.card-header
        h4.card-title List of Uploaded Produce 
    br
    nav
    #nav-tab.nav.nav-tabs(role='tablist')
        //- a#nav-profile-tab.nav-item.nav-link(href='/producelist') A
    #nav-tabContent.tab-content
    br
    table.table.table-bordered 
        thead
            tr
                th Ward
                th Supplier Name
                th Produce Name
                th Quantity
                th Unit Price
                th Total Amount
                th Product Type
                th Image 
                th Approve 
        tbody
            if products.length
                each product in products
                    if product.status = 'Pending' && product.ward === currentUser.ward
                        tr
                            td #{product.ward}
                            td #{product.fullname}
                            td #{product.productname}
                            td #{product.quantity}
                            td #{product.unitprice}
                            td #{product.totalamount}
                            td #{product.producttype}
                            //- td #{product.status}
                            td 
                                img(src="/"+product.uploadimage, alt="Image" width='150px' height="150px")
                            //- td #{moment(us)}
                            td
                                a.btn.btn-primary.btn-block(href='/produce/approve/'+product._id) Approve
                            //- td
                            //-     a.btn.btn-secondary.btn-block(href='/produce/approve/'+product._id) Approve
                            //- td
                            //-     form(method="post" action='/produce/delete')
                            //-         input(type="hidden" placeholder="" name="id", value=product._id)
                            //-         button.btn.btn-danger.btn-block(type="submit") Delete
    div.form-row
        div.col.form-group
            a(class='button' href='/masajjaAfodashboard') Back

block footer
    div.col-md-12 

doctype html
head
  title Login
  meta(charset='utf-8')
  meta(name='viewport' content='width=device-width, initial-scale=1, shrink-to-fit=no')
  link(rel='stylesheet' href='https://cdn.jsdelivr.net/npm/bootstrap@5.2.0/dist/css/bootstrap.min.css' integrity='sha384-gH2yIJqKdNHPEq0n4Mqa/HGKIhSkIHeL5AyhkYV8i59U5AR6csBvApHHNl/vI1Bx' crossorigin='anonymous')
  link(rel='stylesheet' href='css/login.css')
#main-wrapper.container
  .row.justify-content-center
    .col-xl-10
      .card.border-0
        .card-body.p-0
          .row.no-gutters
            .col-lg-6
              .p-5
                .mb-5
                  h3.h4.font-weight-bold.text-theme Login
                h6.h5.mb-0 Welcome back!
                p.text-muted.mt-2.mb-5
                  | Please enter your details to log in.
                form(action='/login' method='post' onsubmit="return formValidatelogin(event);")
                  .form-group
                    label Unique ID
                    input#uniqueid(type='text' name='uniqueid')
                    small#uniqueidError
                  .form-group.mb-5
                    label Password
                    input#password(type='password' name='password')
                    small#passwordError
                    button.btn.btn-theme.btn-secondary(class="text-success" type='submit') Login
            .col-lg-6.d-none.d-lg-inline-block
              .account-block.rounded-right
                .overlay.rounded-right
                .account-testimonial
                  p
                    | &quot;Forget about all the reasons why something may not
                    | work. You only need to find one good reason why it
                    | will.&quot;
  script(src="/JS/form_validationlogin.js") 
      
